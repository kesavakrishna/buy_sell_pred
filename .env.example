# LLM API Keys
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Financial Data APIs
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
POLYGON_API_KEY=your_polygon_key
ALTERNATIVE_ME_API_KEY=your_alternative_me_key  # Fear & Greed Index
GLASSNODE_API_KEY=your_glassnode_key
WHALE_ALERT_API_KEY=your_whale_alert_key

# Exchange APIs (for data collection)
BINANCE_API_KEY=your_binance_key
BINANCE_SECRET_KEY=your_binance_secret
COINBASE_API_KEY=your_coinbase_key
COINBASE_SECRET_KEY=your_coinbase_secret

# Social Media APIs
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=financial_analysis_bot

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/trading_system
REDIS_URL=redis://localhost:6379/0

# Risk Management
MAX_POSITION_RISK=0.02  # 2% max risk per position
MAX_PORTFOLIO_DRAWDOWN=0.15  # 15% max drawdown
EMERGENCY_STOP_LOSS=0.10  # 10% emergency stop

# System Configuration
LOG_LEVEL=INFO
ENVIRONMENT=development
ENABLE_PAPER_TRADING=true